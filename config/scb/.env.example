# =============================================================================
# SCB Profile Environment Configuration
# =============================================================================
# Copy this to .env in the scb profile directory and fill in values.
#
# Fallback chain: profile .env → config/default/.env → root .env
# Variables already set in the environment are never overridden.
# =============================================================================

# === LLM Provider Configuration ===
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# === Authentication ===
# AUTH_ENABLED=false
# AUTH_USERNAME=admin
# AUTH_PASSWORD=

# === Language ===
APP_LANGUAGE=sv
